{
  "description": "smartci build 阶段手写示例 — 直接给 deploy.py 跑，不经过 smartci CLI",
  "_note": "实际跑时由 smartci.manifest_render.BuildManifestAssembler 动态渲染；本文件用于演示 task schema",

  "variables": {
    "team": "team-a",
    "peer": "team-b",
    "peer_version": "latest"
  },

  "tasks": [
    {
      "name": "merge-resource",
      "order": 1,
      "usage": "python -m smartci resource merge --inputs resources/team-a.xml resources/team-b.xml --output resources/final.xml"
    },
    {
      "name": "fetch-peer",
      "order": 2,
      "usage": "echo 'TODO: artifact-cli pull ${peer}-${peer_version}* -o /tmp/smartci-work/peer'",
      "keyword": [
        { "type": "success", "word": "downloaded" },
        { "type": "error",   "word": "404" }
      ]
    },
    {
      "name": "package-fpga",
      "order": 3,
      "usage": "echo 'TODO: build fpga 联合包'"
    },
    {
      "name": "package-emu",
      "order": 3,
      "usage": "echo 'TODO: build emu 联合包'"
    },
    {
      "name": "upload",
      "order": 4,
      "usage": "echo 'TODO: artifact-cli push /tmp/smartci-work/*.tar.gz'"
    }
  ]
}
