{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "smartci: --help",
      "type": "shell",
      "command": "python -m smartci --help",
      "options": { "cwd": "${workspaceFolder}/projects/ai-smartci" },
      "problemMatcher": []
    },
    {
      "label": "smartci: pip install",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "options": { "cwd": "${workspaceFolder}/projects/ai-smartci" },
      "problemMatcher": []
    },
    {
      "label": "smartci: pytest + doctest",
      "type": "shell",
      "command": "pytest tests/ --doctest-modules smartci/ -v",
      "options": { "cwd": "${workspaceFolder}/projects/ai-smartci" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "smartci: ruff check",
      "type": "shell",
      "command": "ruff check smartci tests",
      "options": { "cwd": "${workspaceFolder}/projects/ai-smartci" },
      "problemMatcher": []
    },
    {
      "label": "smartci: mypy",
      "type": "shell",
      "command": "mypy smartci --python-version 3.9",
      "options": { "cwd": "${workspaceFolder}/projects/ai-smartci" },
      "problemMatcher": []
    },
    {
      "label": "deploy.py: fpga smoke manifest",
      "type": "shell",
      "command": "python scripts/deploy.py --manifest=platforms/fpga/smoke.manifest.json --vars-file=platforms/_shared/vars.json --platform=fpga --version=v1.2.3 --commit_short=a4f9d012 -y",
      "options": { "cwd": "${workspaceFolder}/projects/ai-smartci" },
      "problemMatcher": []
    },
    {
      "label": "deploy.py: _shared/merge manifest",
      "type": "shell",
      "command": "python scripts/deploy.py --manifest=platforms/_shared/merge.manifest.json --vars-file=platforms/_shared/vars.json -y",
      "options": { "cwd": "${workspaceFolder}/projects/ai-smartci" },
      "problemMatcher": []
    }
  ]
}
