{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CI 全量检查",
      "type": "shell",
      "command": "./ci.sh all",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"],
      "detail": "clean → configure → build → test",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "运行测试",
      "type": "shell",
      "command": "./ci.sh test",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": ["$gcc"],
      "detail": "运行全部 ut + it 测试",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Debug 配置",
      "type": "shell",
      "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
      "problemMatcher": ["$gcc"],
      "detail": "生成 Debug 构建 + compile_commands.json",
      "options": { "cwd": "${workspaceFolder}" }
    }
  ]
}
