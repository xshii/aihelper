# Toolchain: 自定义编译器模板
# 复制此文件为 toolchain-custom.cmake，修改路径后使用:
#   cmake -B build -DCMAKE_TOOLCHAIN_FILE=cmake/toolchain-custom.cmake

# set(CMAKE_SYSTEM_NAME Generic)       # 交叉编译时取消注释
# set(CMAKE_SYSTEM_PROCESSOR your_dsp) # 目标处理器

set(CMAKE_C_COMPILER   /path/to/your-gcc)
set(CMAKE_CXX_COMPILER /path/to/your-g++)

# 交叉编译时取消注释
# set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)
# set(DSC_CROSS_COMPILING ON)
