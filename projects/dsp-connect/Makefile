# PURPOSE: Build system for dsp-connect — static library, demo, and tests
# PATTERN: Single Makefile with pattern rules and automatic dependency tracking
# FOR: Weak AI to reference when building a C project with proper dep management

# ------------------------------------------------------------------ #
# Variables                                                          #
# ------------------------------------------------------------------ #

CC       = gcc
CFLAGS   = -Wall -Wextra -Wpedantic -std=c11 -Isrc
LDFLAGS  =
BUILD    = build

# Optional: link libdwarf if available (set DSC_USE_LIBDWARF=1 to enable)
ifdef DSC_USE_LIBDWARF
CFLAGS  += -DDSC_USE_LIBDWARF
LDFLAGS += -ldwarf -lelf
endif

# ------------------------------------------------------------------ #
# Source collection                                                  #
# ------------------------------------------------------------------ #

# All library .c files under src/ (excluding demo_main.c)
LIB_SRCS := $(filter-out src/demo_main.c, \
               $(wildcard src/*/*.c))

# Demo main
DEMO_SRC := src/demo_main.c

# Test sources (tests/ and tests/mocks/)
TEST_SRCS := $(wildcard tests/*.c) $(wildcard tests/mocks/*.c)

# ------------------------------------------------------------------ #
# Object files — mirror src/ tree under build/obj/                   #
# ------------------------------------------------------------------ #

LIB_OBJS  := $(patsubst src/%.c,$(BUILD)/obj/src/%.o,$(LIB_SRCS))
DEMO_OBJ  := $(patsubst src/%.c,$(BUILD)/obj/src/%.o,$(DEMO_SRC))
TEST_OBJS := $(patsubst tests/%.c,$(BUILD)/obj/tests/%.o,$(TEST_SRCS))

# Dependency files generated by -MMD -MP
DEPS := $(LIB_OBJS:.o=.d) $(DEMO_OBJ:.o=.d) $(TEST_OBJS:.o=.d)

# ------------------------------------------------------------------ #
# Output artifacts                                                   #
# ------------------------------------------------------------------ #

LIB       := $(BUILD)/libdsc.a
DEMO      := $(BUILD)/dsc_demo
TEST_BIN  := $(BUILD)/test_runner

# ------------------------------------------------------------------ #
# Default target                                                     #
# ------------------------------------------------------------------ #

.PHONY: all demo test clean check format

all: $(LIB)

# ------------------------------------------------------------------ #
# Static library                                                     #
# ------------------------------------------------------------------ #

$(LIB): $(LIB_OBJS)
	@echo "  AR    $@"
	@$(AR) rcs $@ $^

# ------------------------------------------------------------------ #
# Demo binary                                                        #
# ------------------------------------------------------------------ #

demo: $(DEMO)

$(DEMO): $(DEMO_OBJ) $(LIB)
	@echo "  LD    $@"
	@$(CC) $(CFLAGS) -o $@ $< -L$(BUILD) -ldsc $(LDFLAGS)

# ------------------------------------------------------------------ #
# Test binary — build and run                                        #
# ------------------------------------------------------------------ #

test: $(TEST_BIN)
	@echo "  RUN   $@"
	@./$(TEST_BIN)

$(TEST_BIN): $(TEST_OBJS) $(LIB)
	@echo "  LD    $@"
	@$(CC) $(CFLAGS) -o $@ $(TEST_OBJS) -L$(BUILD) -ldsc $(LDFLAGS)

# ------------------------------------------------------------------ #
# Pattern rules with automatic dependency generation                 #
# ------------------------------------------------------------------ #

# Compile src/ files
$(BUILD)/obj/src/%.o: src/%.c
	@mkdir -p $(dir $@)
	@echo "  CC    $<"
	@$(CC) $(CFLAGS) -MMD -MP -c -o $@ $<

# Compile tests/ files
$(BUILD)/obj/tests/%.o: tests/%.c
	@mkdir -p $(dir $@)
	@echo "  CC    $<"
	@$(CC) $(CFLAGS) -Itests -MMD -MP -c -o $@ $<

# ------------------------------------------------------------------ #
# Include generated dependency files (if they exist)                 #
# ------------------------------------------------------------------ #

-include $(DEPS)

# ------------------------------------------------------------------ #
# Check — same build but with -Werror                                #
# ------------------------------------------------------------------ #

check:
	@$(MAKE) --no-print-directory all CFLAGS="$(CFLAGS) -Werror"

# ------------------------------------------------------------------ #
# Format — optional clang-format (don't fail if not installed)       #
# ------------------------------------------------------------------ #

format:
	@if command -v clang-format >/dev/null 2>&1; then \
		echo "  FMT   src/ tests/"; \
		find src tests -name '*.c' -o -name '*.h' | xargs clang-format -i; \
	else \
		echo "  SKIP  clang-format not found"; \
	fi

# ------------------------------------------------------------------ #
# Clean                                                              #
# ------------------------------------------------------------------ #

clean:
	rm -rf $(BUILD)/
