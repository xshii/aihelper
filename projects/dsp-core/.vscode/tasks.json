{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "[GC] 运行当前文件",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["${file}"],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": ["$python"],
      "detail": "用 .venv 的 python 运行当前打开的文件",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "[GC] 运行当前文件（带参数）",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["${file}", "${input:args}"],
      "problemMatcher": ["$python"],
      "detail": "运行当前文件 + 自定义参数",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "[GC] CI 全量检查",
      "type": "shell",
      "command": "make ci",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$python"],
      "detail": "ruff + import-linter + radon + vulture + pytest（8 种策略）",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "[GC] 编译 Golden C Bindings",
      "type": "shell",
      "command": "make build-golden",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "cmake + build → _raw_bindings.so",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "[GC] 生成生产环境 (.venv-prod)",
      "type": "shell",
      "command": "python3 -m venv .venv-prod && .venv-prod/bin/pip install -U pip && .venv-prod/bin/pip install -e .",
      "problemMatcher": [],
      "detail": "创建 .venv-prod 并只安装运行时依赖（torch/numpy/pybind11）",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "[GC] 生成测试环境 (.venv)",
      "type": "shell",
      "command": "python3 -m venv .venv && .venv/bin/pip install -U pip && .venv/bin/pip install -e '.[all]'",
      "problemMatcher": [],
      "detail": "创建 .venv 并安装全部依赖（运行时 + dev + viz），适合开发/调试",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "[GC] 选择检查项",
      "type": "shell",
      "command": "make ${input:target}",
      "problemMatcher": ["$python"],
      "options": { "cwd": "${workspaceFolder}" }
    }
  ],
  "inputs": [
    {
      "id": "args",
      "type": "promptString",
      "description": "输入参数（如: generate_input, use_input）"
    },
    {
      "id": "target",
      "type": "pickString",
      "description": "选择要运行的检查",
      "options": ["ci", "test", "test-ut", "test-it", "test-st", "test-cov", "lint", "quality", "smoke", "check", "build-golden", "clean"],
      "default": "test"
    }
  ]
}
